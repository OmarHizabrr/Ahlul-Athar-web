rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwnerUid(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ملفات المستخدمين — التعديل لاحقاً حسب سياسة التطبيق
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwnerUid(userId);
      allow update: if isOwnerUid(userId);
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /enrollment_requests/{id} {
      allow read, write: if signedIn();
    }

    match /numbers/{courseId}/numbers/{studentId} {
      allow read, write: if signedIn();
    }

    match /Mycourses/{userId}/Mycourses/{courseId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /posts/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /notifications/{id} {
      allow read, write: if signedIn();
    }
  }
}
