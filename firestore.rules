// Web: ارفع لـ GitHub — Vercel ينشّر الواجهة (مشروع ahlul-athar-web). انظر vercel.json.
// Firebase (قواعد فقط): npm run deploy:firebase  أو: firebase deploy --only firestore,storage
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwnerUid(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    // مسؤول: users.role (ويب/تطبيق) أو isAdmin أو وجود سجل في admins/{uid} (ميراث Flutter)
    function isAdmin() {
      return signedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(userPath()) && (
          get(userPath()).data.role == 'admin' ||
          get(userPath()).data.role == 'Admin' ||
          get(userPath()).data.isAdmin == true
        ))
      );
    }

    match /users/{userId} {
      allow read: if isOwnerUid(userId) || isAdmin();
      allow create, update: if isOwnerUid(userId);
    }

    match /courses/{courseId} {
      allow read: if isAdmin() || resource.data.isActive == true;
      allow create, update, delete: if isAdmin();
    }

    match /enrollment_requests/{id} {
      allow create: if signedIn() &&
        request.resource.data.studentId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.requestType is string;

      allow read: if isAdmin() || resource.data.studentId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    match /numbers/{courseId}/numbers/{studentId} {
      allow read: if isAdmin() || isOwnerUid(studentId);
      allow create, update: if isAdmin() || isOwnerUid(studentId);
      allow delete: if isAdmin();
    }

    match /Mycourses/{userId}/Mycourses/{courseId} {
      allow read: if isAdmin() || isOwnerUid(userId);
      allow create, update, delete: if isAdmin() || isOwnerUid(userId);
    }

    // دروس المقرر — نفس Flutter: lessons/{courseId}/lessons/{lessonId}
    match /lessons/{courseId}/lessons/{lessonId} {
      allow read: if isAdmin() ||
        (signedIn() &&
          exists(/databases/$(database)/documents/Mycourses/$(request.auth.uid)/Mycourses/$(courseId)));
      allow create, update, delete: if isAdmin();
    }

    // مرفقات الدرس — نفس Flutter: lesson_attachments/{lessonId}/lesson_attachments/{id}
    // (معرّف الدرس فقط في المسار؛ تقييد إضافي يتطلّب تكرار courseId في المستندات)
    match /lesson_attachments/{lessonId}/lesson_attachments/{attachmentId} {
      allow read: if isAdmin() || signedIn();
      allow create, update, delete: if isAdmin();
    }

    // تقدم الطالب لكل درس (فتح/قفل) — lessonAccessService + Flutter
    match /student_lesson_progress/{studentId}/student_lesson_progress/{lessonId} {
      allow read: if isAdmin() || isOwnerUid(studentId);
      allow create, update: if isAdmin() || isOwnerUid(studentId);
      allow delete: if isAdmin();
    }

    // ملفات الاختبارات لكل درس (قراءة للمستخدم المسجّل — التحقق من المقرر في التطبيق)
    match /quiz_files/{lessonId}/quiz_files/{fileId} {
      allow read: if isAdmin() || signedIn();
      allow create, update, delete: if isAdmin();
    }

    // أسئلة الاختبار — نفس مسار تطبيق Flutter: quiz_questions/{quizFileId}/quiz_questions
    match /quiz_questions/{quizFileId}/quiz_questions/{questionId} {
      allow read: if isAdmin() || signedIn();
      allow create, update, delete: if isAdmin();
    }

    // خيارات أسئلة الاختيار من متعدد
    match /question_options/{questionId}/question_options/{optionId} {
      allow read: if isAdmin() || signedIn();
      allow create, update, delete: if isAdmin();
    }

    // إجابات الاختبار — الطالب لا يجوز أن ينشئ/يحدّث بحالة graded (فقط completed/submitted)
    match /quiz_answers/{quizFileId}/quiz_answers/{answerId} {
      allow read: if isAdmin() ||
        (signedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isAdmin() || (
        signedIn() &&
        request.resource.data.studentId == request.auth.uid &&
        (!('status' in request.resource.data) ||
         request.resource.data.status in ['completed', 'submitted'])
      );
      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.studentId == request.auth.uid &&
        request.resource.data.studentId == resource.data.studentId &&
        (!('status' in request.resource.data) ||
         request.resource.data.status in ['completed', 'submitted']) &&
        (!('status' in resource.data) || resource.data.status in ['completed', 'submitted'])
      );
      allow delete: if isAdmin();
    }

    match /posts/{id} {
      // دعم isPublished أو published (ميراث بيانات)
      allow read: if isAdmin() ||
        resource.data.isPublished == true ||
        resource.data.published == true;
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() && request.resource.data.keys().hasAll(['userId', 'title', 'body']);
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // قنوات التواصل العامة (صفحة «تواصل معنا») — قراءة للجميع، التعديل للمسؤولين فقط
    match /contact_infos/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
